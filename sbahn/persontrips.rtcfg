<configuration>
    <net-file value="berlin-sbahn-stations.net.xml.gz"/>
    <output-trip-file value="persons.trips.xml"/>
    <persontrips value="True"/>
    <trip-attributes value="modes='public'"/>
    <min-distance value="100.0"/>
    <no-validate value="True"/>
    <begin value="8:0:0"/>
    <end value="9:0:0"/>
    <insertion-rate value="240000"/>
</configuration>
